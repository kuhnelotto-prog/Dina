# Bitget API (демо-ключи)
BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here
BITGET_PASSPHRASE=your_passphrase_here

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ALLOWED_IDS=your_user_id_here

# Торговля
DRY_RUN=true                     # сначала всегда true
STARTING_BALANCE=10000
SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT,BNBUSDT,XRPUSDT,AVAXUSDT,MATICUSDT,LINKUSDT,UNIUSDT,AAVEUSDT

# Риск-менеджмент
BASE_RISK_PCT=1.0
MAX_RISK_PCT=2.0
MAX_POSITIONS=1
DAILY_LOSS_LIMIT=5.0
MAX_CONSECUTIVE_LOSSES=5

# Трейлинг
TRAILING_ACTIVATION_ATR=0.5
TRAILING_STEP_ATR=0.2
TRAILING_DIST_ATR=1.2

# Мульти-таймфрейм
TIMEFRAMES=15m,1h,4h
TIMEFRAME_WEIGHTS=0.2,0.3,0.5

# LLM фильтр (DeepSeek)
LLM_PROVIDER=deepseek
DEEPSEEK_MODE=ollama            # или api
DEEPSEEK_API_KEY=
OLLAMA_URL=http://localhost:11434/api/chat
DEEPSEEK_MODEL=deepseek-v3

# База данных
DB_PATH=dina.db

# Опционально
WHALE_ALERT_API_KEY=
FRED_API_KEY=

# Ночной режим уведомлений
SILENT_HOURS_START=23
SILENT_HOURS_END=7
MAX_TOTAL_EXPOSURE=50000.0